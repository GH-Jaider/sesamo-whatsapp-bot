# Caddyfile — Reverse proxy for the WhatsApp bot
#
# Temporary public HTTPS hostname using sslip.io for the current Droplet IP.
# sslip.io resolves 45-55-172-5.sslip.io -> 45.55.172.5, which lets Caddy
# obtain a valid Let's Encrypt certificate even before buying a custom domain.
#
# Later, replace this hostname with your real domain, for example:
#   bot.example.com {
#       reverse_proxy bot:3000
#   }

45-55-172-5.sslip.io {
	reverse_proxy bot:3000
}
