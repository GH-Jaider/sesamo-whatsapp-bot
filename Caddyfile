# Caddyfile — Reverse proxy for the WhatsApp bot
#
# HTTP-only mode (no domain yet):
#   Uses bare port 80, no TLS.
#
# To enable automatic HTTPS, replace "http://:80" with your domain:
#   bot.example.com {
#       reverse_proxy bot:3000
#   }
# Caddy will automatically obtain and renew a Let's Encrypt certificate.

http://:80 {
	reverse_proxy bot:3000
}
