# --- WhatsApp Cloud API ---
# Phone Number ID from Meta Dashboard > WhatsApp > API Setup
WA_PHONE_NUMBER_ID=""
# Permanent system user token from Meta Business Settings > System Users
WA_ACCESS_TOKEN=""
# Any string you choose — must match what you enter in Meta webhook config
WA_VERIFY_TOKEN=""
# App Secret from Meta Dashboard > App Settings > Basic (optional, for webhook signature validation)
WA_APP_SECRET=""

# --- Bot Config ---
# Admin phone number (country code + number, no +), e.g. "573001234567"
ADMIN_PHONE=""
# Nequi number shown to customers for payment
NEQUI_NUMBER=""

# --- Server ---
PORT="3000"
NODE_ENV="production"
LOG_LEVEL="info"
# Root directory for static files (menu, privacy policy). Default: ".." (dev mode)
# Set to "./static" in Docker production
# STATIC_ROOT="./static"
